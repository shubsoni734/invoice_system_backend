            "url": "{{base_url}}/api/v1/templates/{{template_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{org_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Invoices",
      "item": [
        {
          "name": "List Invoices",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/invoices",
            "header": [{ "key": "Authorization", "value": "Bearer {{org_token}}" }]
          }
        },
        {
          "name": "Get Invoice",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/invoices/{{invoice_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{org_token}}" }]
          }
        },
        {
          "name": "Create Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.invoice && res.data.invoice.id) {",
                  "  pm.collectionVariables.set('invoice_id', res.data.invoice.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/invoices",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{org_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"{{customer_id}}\",\n  \"session_id\": \"{{session_id}}\",\n  \"invoice_number\": \"INV-2025-001\",\n  \"issued_date\": \"2025-03-17\",\n  \"due_date\": \"2025-04-17\",\n  \"currency\": \"INR\",\n  \"notes\": \"Thank you for your business.\",\n  \"terms\": \"Payment due within 30 days.\",\n  \"items\": [\n    {\n      \"service_id\": \"{{service_id}}\",\n      \"description\": \"Web Development - 10 hours\",\n      \"quantity\": 10,\n      \"unit_price\": 5000.00,\n      \"tax_rate\": 18,\n      \"sort_order\": 1\n    },\n    {\n      \"description\": \"Domain Registration\",\n      \"quantity\": 1,\n      \"unit_price\": 1500.00,\n      \"tax_rate\": 18,\n      \"sort_order\": 2\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Cancel Invoice",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/invoices/{{invoice_id}}/cancel",
            "header": [{ "key": "Authorization", "value": "Bearer {{org_token}}" }]
          }
        },
        {
          "name": "Download Invoice PDF",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/invoices/{{invoice_id}}/pdf",
            "header": [{ "key": "Authorization", "value": "Bearer {{org_token}}" }]
          }
        },
        {
          "name": "Get Invoice Payments",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/invoices/{{invoice_id}}/payments",
            "header": [{ "key": "Authorization", "value": "Bearer {{org_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Record Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('payment_id', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/payments",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{org_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoice_id\": \"{{invoice_id}}\",\n  \"amount\": 59000.00,\n  \"method\": \"bank_transfer\",\n  \"reference\": \"TXN123456\",\n  \"notes\": \"Full payment received\",\n  \"payment_date\": \"2025-03-17\"\n}"
            }
          }
        },
        {
          "name": "Delete Payment",
          "request": {
            "method": "DELETE",
